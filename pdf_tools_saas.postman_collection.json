{
  "info": {
    "_postman_id": "pdf-tools-saas-collection",
    "name": "PDF Tools SaaS API",
    "description": "Postman collection for testing the PDF Tools SaaS API endpoints one by one.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Checks",
      "item": [
        {
          "name": "Root Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "    pm.environment.set(\"jwt_token\", response.token);",
                  "    pm.collectionVariables.set(\"jwt_token\", response.token);",
                  "    console.log(\"JWT Token set automatically!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"securePassword123\",\n  \"name\": \"Alok Kumar\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "    pm.environment.set(\"jwt_token\", response.token);",
                  "    pm.collectionVariables.set(\"jwt_token\", response.token);",
                  "    console.log(\"JWT Token set automatically!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users Module",
      "item": [
        {
          "name": "Get Profile & Usage",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Upload Module",
      "item": [
        {
          "name": "Request Pre-signed S3 URL",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fileName\": \"document.pdf\",\n  \"contentType\": \"application/pdf\",\n  \"fileSize\": 1048576\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/upload/presign",
              "host": ["{{baseUrl}}"],
              "path": ["api", "upload", "presign"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Jobs Module",
      "item": [
        {
          "name": "Create Processing Job (Merge)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.job && response.job.id) {",
                  "    pm.collectionVariables.set(\"lastJobId\", response.job.id);",
                  "    console.log(\"Saved lastJobId:\", response.job.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tool\": \"merge\",\n  \"inputFiles\": [\n    \"pdf-saas-uploads/user-mock-user-id/file1.pdf\",\n    \"pdf-saas-uploads/user-mock-user-id/file2.pdf\"\n  ],\n  \"options\": {\n    \"order\": [0, 1]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/jobs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs"]
            }
          },
          "response": []
        },
        {
          "name": "Poll Job Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/{{lastJobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs", "{{lastJobId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Billing Module",
      "item": [
        {
          "name": "Initiate Razorpay Checkout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": \"plan_N1234abc\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/billing/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "billing", "checkout"]
            }
          },
          "response": []
        },
        {
          "name": "Check Subscription Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/billing/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "billing", "status"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Webhooks Module",
      "item": [
        {
          "name": "Simulate Razorpay Webhook Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "x-razorpay-signature",
                "value": "simulate_signature",
                "type": "text",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"subscription.charged\",\n  \"payload\": {\n    \"subscription\": {\n      \"entity\": {\n        \"id\": \"sub_N9876xyz\",\n        \"status\": \"active\",\n        \"current_end\": 1735689600\n      }\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/webhooks/razorpay",
              "host": ["{{baseUrl}}"],
              "path": ["api", "webhooks", "razorpay"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "lastJobId",
      "value": "",
      "type": "string"
    }
  ]
}
