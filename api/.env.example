NODE_ENV=development
PORT=5000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=pdf_saas
DB_CONNECTION_LIMIT=10

# Redis (BullMQ + rate limiting). Use rediss:// for TLS providers like Upstash.
REDIS_URL=redis://localhost:6379

# Auth — MUST be at least 32 characters, high entropy, from a secret manager in prod.
JWT_SECRET=change_me_to_a_long_random_32plus_char_secret

# Security / networking
# Comma-separated list of allowed browser origins (no trailing slash).
CORS_ORIGINS=http://localhost:5173,http://localhost:5000
# Max JSON request body size.
MAX_JSON_BODY=100kb
# TTL (seconds) for signed result-download URLs handed to the job owner.
DOWNLOAD_URL_TTL=300
# Job file retention (minutes) and presigned upload URL TTL (seconds).
JOB_TTL_MINUTES=60
PRESIGN_TTL_SECONDS=900
# Token TTLs and bcrypt cost.
JWT_EXPIRES_IN=7d
GUEST_JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12
# Admin token protecting the queue dashboard at /admin/queues (Basic Auth,
# any username + this value as password). Leave unset to disable the dashboard.
ADMIN_TOKEN=

# DigitalOcean Spaces (S3-compatible). Bucket MUST be private (no public read).
DO_SPACES_KEY=your_spaces_key
DO_SPACES_SECRET=your_spaces_secret
DO_SPACES_REGION=blr1
DO_SPACES_BUCKET=your_bucket_name
DO_SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com

# Optional Razorpay Integration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
