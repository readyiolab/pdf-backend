NODE_ENV=development
PORT=5000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=pdf_saas
DB_CONNECTION_LIMIT=10

# Redis (BullMQ + rate limiting). Use rediss:// for TLS providers like Upstash.
REDIS_URL=redis://localhost:6379

# Auth — MUST be at least 32 characters, high entropy, from a secret manager in prod.
JWT_SECRET=change_me_to_a_long_random_32plus_char_secret

# Security / networking
# Comma-separated list of allowed browser origins (no trailing slash).
CORS_ORIGINS=http://localhost:5174,http://localhost:5000
# Max JSON request body size.
MAX_JSON_BODY=100kb
# Body limit for the signing router only (the field designer PUTs a document's
# whole field set at once, which exceeds the global 100kb cap).
SIGNING_MAX_JSON_BODY=2mb
# TTL (seconds) for signed result-download URLs handed to the job owner.
DOWNLOAD_URL_TTL=300
# Job file retention (minutes) and presigned upload URL TTL (seconds).
JOB_TTL_MINUTES=60
PRESIGN_TTL_SECONDS=900
# Token TTLs and bcrypt cost.
JWT_EXPIRES_IN=7d
GUEST_JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12
# Admin token protecting the queue dashboard at /admin/queues (Basic Auth,
# any username + this value as password). Leave unset to disable the dashboard.
ADMIN_TOKEN=

# DigitalOcean Spaces (S3-compatible). Bucket MUST be private (no public read).
DO_SPACES_KEY=your_spaces_key
DO_SPACES_SECRET=your_spaces_secret
DO_SPACES_REGION=blr1
DO_SPACES_BUCKET=your_bucket_name
DO_SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com

# Optional Razorpay Integration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# --- Email (SMTP) ---
# Carries signing invitations and OTPs. If unset, the mailer reports itself
# unconfigured and /send fails loudly instead of silently dropping mail.
# For Gmail: host=smtp.gmail.com, port=465, secure=true, and SMTP_PASS must be
# an App Password (requires 2FA) — a normal account password will NOT work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
# true = implicit TLS (465); false = STARTTLS (587). Never send these plaintext —
# the messages carry signing links, which are bearer credentials.
SMTP_SECURE=true
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_app_password
# Gmail IGNORES this and rewrites From to SMTP_USER unless it is a verified alias.
SMTP_FROM=YourApp <your_smtp_user>

# Public base URL of the FRONTEND. Signing links are built as ${APP_URL}/sign/<token>,
# so in production this MUST be an address recipients can actually reach.
APP_URL=http://localhost:5174

# --- Digital signature (PAdES/PKCS#7) ---
# Applied to the finished PDF so any later edit breaks the signature in Adobe /
# any reader. Leave SIGNING_P12_BASE64 unset in dev — a self-signed cert is
# generated and cached at SIGNING_CERT_PATH. In production, supply a real
# CA-issued cert (base64 of a .p12); an AATL-chained cert shows a green check.
SIGNING_P12_BASE64=
SIGNING_P12_PASSPHRASE=
SIGNING_CERT_PATH=./signing-cert.p12

# RFC 3161 Timestamp Authority for independent, verifiable signing time.
# Best-effort: if unreachable the signature is still applied. freetsa.org is free.
TSA_URL=https://freetsa.org/tsr
TSA_ENABLED=true


# --- AI (OpenAI) ---
# Powers Chat/Summarize/Explain over PDFs. Optional — without it the AI
# endpoints return a clear 503 instead of failing to boot. Each call costs
# money per token; monthly usage is bounded by PLAN_LIMITS.maxMonthlyAiCredits.
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
# Set a model your key can access. gpt-4o-mini is cheap and capable for PDF Q&A.
AI_MODEL=gpt-4o-mini
AI_MAX_TEXT_CHARS=400000
