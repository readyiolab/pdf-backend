NODE_ENV=development
PORT=5001

# MySQL (same database as the API)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=pdf_saas
DB_CONNECTION_LIMIT=10

# Redis (BullMQ). Use rediss:// for TLS providers like Upstash.
REDIS_URL=redis://localhost:6379

# DigitalOcean Spaces (S3-compatible). Bucket MUST be private.
DO_SPACES_KEY=your_spaces_key
DO_SPACES_SECRET=your_spaces_secret
DO_SPACES_REGION=blr1
DO_SPACES_BUCKET=your_bucket_name
DO_SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com

# Malware scanning (optional). Leave false unless a clamd daemon is reachable.
CLAMAV_ENABLED=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# How often the cleanup sweep removes expired jobs and their files (minutes).
CLEANUP_INTERVAL_MINUTES=15
# Jobs stuck in PROCESSING longer than this (minutes) are treated as stalled.
STALE_JOB_MINUTES=30
